# LLM API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
MOONSHOT_API_KEY=sk-...
MOONSHOT_API_BASE=https://api.moonshot.cn/v1

# Default Model
AGENT_DEFAULT_MODEL=moonshot/kimi-k2.5
# AGENT_DEFAULT_MODEL=gpt-4o

# Agent Settings
AGENT_MAX_TOKENS=4096
AGENT_TEMPERATURE=0.2
AGENT_MAX_ITERATIONS=50

# Safety Settings
AGENT_MAX_FILE_SIZE=1048576

# Debug Mode
AGENT_DEBUG=false
