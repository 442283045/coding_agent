# LLM API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Default Model
AGENT_DEFAULT_MODEL=claude-3-5-sonnet-20241022
# AGENT_DEFAULT_MODEL=gpt-4o

# Agent Settings
AGENT_MAX_TOKENS=4096
AGENT_TEMPERATURE=0.2
AGENT_MAX_ITERATIONS=50

# Safety Settings
AGENT_ALLOWED_SHELL_COMMANDS=git,python,pytest,ls,cat,echo,find,grep
AGENT_MAX_FILE_SIZE=1048576

# Debug Mode
AGENT_DEBUG=false
